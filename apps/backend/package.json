    "seed:pg": "bun --env-file=.env.production prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1051.0",
    "@aws-sdk/client-ssm": "^3.1031.0",
    "@elysiajs/cookie": "^0.8.0",
    "@elysiajs/jwt": "^1.4.1",
    "@elysiajs/swagger": "^1.3.1",
    "@prisma/adapter-libsql": "^7.5.0",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.5.0",
    "elysia": "^1.4.28",
    "shared": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/node": "^25.6.0",
    "prisma": "^7.5.0",
    "tsdown": "^0.21.7"
